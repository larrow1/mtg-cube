    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run dev (server + web)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Open in browser",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/apps/web/src"
        }
    ],
    "compounds": [
        {
            "name": "Dev: server + web + browser",
            "configurations": ["Run dev (server + web)", "Open in browser"]
        }
    ]
}
